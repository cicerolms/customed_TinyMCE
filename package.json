{
  "name": "@cicerolms/vietwork-classic-editor",
  "version": "0.1.0",
  "description": "Reusable classic TinyMCE editor shell for Cloudflare Worker SSR projects",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "tinymce",
    "editor",
    "cloudflare-workers",
    "ssr",
    "cms"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
