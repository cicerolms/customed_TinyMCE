{
  "name": "@cicerolms/vietwork-classic-editor",
  "version": "0.1.2",
  "description": "Reusable classic TinyMCE editor shell for Cloudflare Worker SSR projects",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tailwind.css": "./assets/tailwind.css",
    "./tailwind-preset": "./tailwind.preset.cjs",
    "./styles.css": "./styles.css",
    "./editor-style-self.css": "./editor-style-self.css"
  },
  "files": [
    "dist",
    "assets/tailwind.css",
    "styles.css",
    "editor-style-self.css",
    "tailwind.preset.cjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:styles": "tailwindcss -c tailwind.config.cjs -i ./assets/tailwind.css -o ./styles.css --minify",
    "build": "npm run build:styles && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "tinymce",
    "editor",
    "cloudflare-workers",
    "ssr",
    "cms"
  ],
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
